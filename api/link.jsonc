<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<iframe src="https://link.wentianplays.com?nocache=1" width="100%" height="128" frameborder="0" scrolling="auto" style="border-radius: 8px;" title="文天玩官方域名友链公示" onload="const iframe=this;const baseUrl=iframe.src.split('?')[0];iframe.src=baseUrl+'?t='+Date.now();setInterval(()=>{iframe.src=baseUrl+'?t='+Date.now();},13000);"></iframe>
<iframe src="https://link.wentianplays.com" width="100%" height="128" frameborder="0" scrolling="auto" style="border-radius: 8px;" title="文天玩官方域名友链公示" onload="this.src=this.src.split('?')[0]+'?init='+Date.now(); setInterval(()=>this.src=this.src.split('?')[0]+'?ts='+Date.now(),13000)"></iframe>
<div class="sponsor-section">
<iframe src="https://link.wentianplays.com" width="100%" height="128" frameborder="0" scrolling="auto" style="border-radius: 8px;" title="文天玩官方域名友链公示" onload="setInterval(()=>this.src=this.src.split('?')[0]+'?ts='+Date.now(),13000)"></iframe>
</div>
